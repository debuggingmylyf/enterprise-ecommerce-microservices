# ============================================================
# Enterprise E-Commerce Microservices — Environment Variables
#
# HOW TO USE:
#   cp .env.example .env
#   Fill in all values in .env (especially secrets marked with ← REQUIRED)
#   .env is git-ignored and must NEVER be committed.
# ============================================================

# ── Shared DB credentials ──
POSTGRES_USER=                        # ← REQUIRED
POSTGRES_PASSWORD=                    # ← REQUIRED (secret)

# ── Database names ──
AUTH_POSTGRES_DB=auth_db
PRODUCT_POSTGRES_DB=product_db
INVENTORY_POSTGRES_DB=inventory_db
ORDER_POSTGRES_DB=order_db

# ── Host ports for databases ──
AUTH_POSTGRES_PORT=5433
PRODUCT_POSTGRES_PORT=5435
INVENTORY_POSTGRES_PORT=5436
ORDER_POSTGRES_PORT=5437

# ── Service ports ──
CONFIG_SERVER_PORT=8888
DISCOVERY_SERVER_PORT=8761
AUTH_SERVICE_PORT=8081
PRODUCT_SERVICE_PORT=8082
INVENTORY_SERVICE_PORT=8083
ORDER_SERVICE_PORT=8084
API_GATEWAY_PORT=8282

# ── JWT configuration ──
JWT_SECRET=                           # ← REQUIRED (secret, min 32 chars)
JWT_EXPIRATION=3600000
JWT_ACCESS_EXPIRATION=700000
JWT_REFRESH_EXPIRATION=9000000

# ── JPA ──
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# ── Eureka (overridden per-service by docker-compose.yml in Docker mode) ──
EUREKA_CLIENT_SERVICE_URL_DEFAULTZONE=http://localhost:8761/eureka

# ── Datasource (overridden per-service by docker-compose.yml in Docker mode) ──
SPRING_DATASOURCE_USERNAME=${POSTGRES_USER}
SPRING_DATASOURCE_PASSWORD=${POSTGRES_PASSWORD}
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:<PORT>/<DB>  # set per service for local dev
